# Directory where OAuth token files are stored
GOOGLE_CONFIG_DIR=~/.config/productivity-agent

# Local filename for the OAuth client credentials (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Drive folder ID for NotebookLM uploads
NOTEBOOKLM_DRIVE_FOLDER_ID=

# Colon-separated list of local directories to scan for tagged markdown files
NOTEBOOKLM_SOURCE_DIRS=~/notes
