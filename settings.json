{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gws chat *)",
      "Bash(gws auth *)",
      "Bash(gws --help)",
      "Bash(gws schema *)",
      "Bash(python scripts/auth.py status)",
      "Bash(python3 scripts/auth.py status)",
      "Bash(python3 scripts/chat.py list-spaces)"
    ]
  }
}